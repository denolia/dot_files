{
  "layer": "top",
  "position": "top",
  "height": 32,
  "spacing": 6,

  "modules-left": [
    "sway/workspaces"
  ],

  "modules-center": [
    "sway/window"
  ],

  "modules-right": [
    "custom/audio-device",
    "pulseaudio",
    "network",
    "cpu",
    "memory",
    "sway/language",
    "clock",
    "tray"
  ],

  "sway/workspaces": {
    "disable-scroll": true,
    "all-outputs": true,
    "format": "{name}"
  },

  "sway/window": {
    "format": "{title}",
    "max-length": 60
  },

  "sway/language": {
    "format": "{shortDescription}",
    "tooltip-format": "{long}"
  },

  "pulseaudio": {
    "format": "VOL {volume}%",
    "format-muted": "MUTE",
    "scroll-step": 5
  },

  "custom/audio-device": {
    "exec": "~/.config/waybar/scripts/audio-device.sh status",
    "return-type": "json",
    "interval": 5,
    "signal": 8,
    "on-click": "~/.config/waybar/scripts/audio-device.sh menu"
  },

  "network": {
    "format-wifi": "WIFI {signalStrength}%",
    "format-ethernet": "ETH",
    "format-disconnected": "OFFLINE"
  },

  "cpu": {
    "format": "CPU {usage}%"
  },

  "memory": {
    "format": "RAM {}%"
  },

  "clock": {
    "format": "{:%H:%M  %d.%m.%Y}"
  },

  "tray": {
    "spacing": 10
  }
}
